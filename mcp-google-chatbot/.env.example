# Google Chat Configuration
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_PROJECT_ID=[PLACEHOLDER_GOOGLE_PROJECT_ID]
GOOGLE_CHAT_BOT_EMAIL=[PLACEHOLDER_SERVICE_ACCOUNT_EMAIL]

# MyCarrierPackets API Configuration
BEARER_TOKEN=[PLACEHOLDER_MCP_API_BEARER_TOKEN]
REFRESH_TOKEN=[PLACEHOLDER_MCP_API_REFRESH_TOKEN]
TOKEN_ENDPOINT_URL=[PLACEHOLDER_MCP_API_TOKEN_ENDPOINT]

# Application Configuration
PORT=8080
APP_NAME=mcp-google-chatbot
LOG_LEVEL=info

# Optional: Webhook verification
CHAT_WEBHOOK_TOKEN=your_webhook_verification_token
